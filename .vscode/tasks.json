{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo test",
      "type": "shell",
      "command": "cargo test --locked",
      "problemMatcher": "$rustc",
      "group": "test"
    },
    {
      "label": "node tests",
      "type": "shell",
      "command": "node --test tests/node/*.test.js",
      "group": "test"
    },
    {
      "label": "ci",
      "type": "shell",
      "command": "bash scripts/ci.sh",
      "group": "build"
    }
  ]
}
